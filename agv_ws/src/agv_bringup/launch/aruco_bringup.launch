<launch>
  <arg name="enable_imu" default="false" />
  <arg name="enable_realsense_sync" default="true" />
  <arg name="image_topic" default="/camera/color/image_raw" />
  <arg name="camera_info_topic" default="/camera/color/camera_info" />
  <arg name="dictionary" default="original" />
  <arg name="marker_size" default="0.15" />
  <arg name="target_id" default="503" />
  <arg name="print_period" default="0.5" />
  <arg name="publish_image" default="false" />
  <arg name="publish_pose" default="true" />
  <arg name="pose_topic" default="/aruco/target_pose" />

  <include file="$(find agv_bringup)/launch/bringup.launch">
    <arg name="enable_imu" value="$(arg enable_imu)" />
    <arg name="enable_realsense_sync" value="$(arg enable_realsense_sync)" />
  </include>

  <include file="$(find agv_bringup)/launch/aruco.launch">
    <arg name="image_topic" value="$(arg image_topic)" />
    <arg name="camera_info_topic" value="$(arg camera_info_topic)" />
    <arg name="dictionary" value="$(arg dictionary)" />
    <arg name="marker_size" value="$(arg marker_size)" />
    <arg name="target_id" value="$(arg target_id)" />
    <arg name="print_period" value="$(arg print_period)" />
    <arg name="publish_image" value="$(arg publish_image)" />
    <arg name="publish_pose" value="$(arg publish_pose)" />
    <arg name="pose_topic" value="$(arg pose_topic)" />
  </include>
</launch>
