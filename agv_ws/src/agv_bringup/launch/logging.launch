<launch>

  <!-- Dataset recording launch file.
       Set these env vars before running, e.g.:
         export ROBOT_NAME=agv1
         export SCENARIO=corridor_loop
         export DATESTAMP=$(date +%Y%m%d_%H%M%S)
       Defaults are provided so the launch will not crash if unset. -->

  <arg name="robot_name" default="$(optenv ROBOT_NAME agv_unknown)" />
  <arg name="scenario"   default="$(optenv SCENARIO unknown_scenario)" />
  <arg name="datestamp"  default="$(optenv DATESTAMP 000000_000000)" />
  <arg name="mocap_topic" default="$(optenv MOCAP_TOPIC /phasespace/rigids)" />
  <arg name="enable_imu" default="$(optenv ENABLE_IMU false)" />
  <arg name="enable_realsense_sync" default="$(optenv ENABLE_REALSENSE_SYNC true)" />
  <arg name="color_width" default="$(optenv CAMERA_COLOR_WIDTH 640)" />
  <arg name="color_height" default="$(optenv CAMERA_COLOR_HEIGHT 480)" />
  <arg name="color_fps" default="$(optenv CAMERA_COLOR_FPS 15)" />
  <arg name="depth_width" default="$(optenv CAMERA_DEPTH_WIDTH 640)" />
  <arg name="depth_height" default="$(optenv CAMERA_DEPTH_HEIGHT 480)" />
  <arg name="depth_fps" default="$(optenv CAMERA_DEPTH_FPS 15)" />
  <arg name="enable_aruco" default="$(optenv ENABLE_ARUCO false)" />
  <arg name="aruco_dictionary" default="$(optenv ARUCO_DICTIONARY original)" />
  <arg name="aruco_marker_size" default="$(optenv ARUCO_MARKER_SIZE 0.15)" />
  <arg name="aruco_target_id" default="$(optenv ARUCO_TARGET_ID 503)" />

  <include file="$(find agv_bringup)/launch/bringup.launch">
    <arg name="enable_imu" value="$(arg enable_imu)" />
    <arg name="enable_realsense_sync" value="$(arg enable_realsense_sync)" />
    <arg name="color_width" value="$(arg color_width)" />
    <arg name="color_height" value="$(arg color_height)" />
    <arg name="color_fps" value="$(arg color_fps)" />
    <arg name="depth_width" value="$(arg depth_width)" />
    <arg name="depth_height" value="$(arg depth_height)" />
    <arg name="depth_fps" value="$(arg depth_fps)" />
  </include>

  <include if="$(arg enable_aruco)" file="$(find agv_bringup)/launch/aruco.launch">
    <arg name="dictionary" value="$(arg aruco_dictionary)" />
    <arg name="marker_size" value="$(arg aruco_marker_size)" />
    <arg name="target_id" value="$(arg aruco_target_id)" />
    <arg name="publish_image" value="false" />
    <arg name="publish_pose" value="true" />
  </include>

  <node pkg="rosbag" type="record" name="dataset_bagger" output="screen"
        args="--buffsize=2048 --lz4
              -O $(env HOME)/agv_data/$(arg robot_name)_$(arg scenario)_$(arg datestamp)
              /scan
              /odom
              /cmd_vel
              /tf
              /tf_static
              /camera/color/image_raw
              /camera/color/camera_info
              /camera/depth/camera_info
              /camera/aligned_depth_to_color/image_raw
              /camera/aligned_depth_to_color/camera_info
              /camera/extrinsics/depth_to_color
              /imu
              /camera/imu
              /camera/accel/sample
              /camera/gyro/sample
              /camera/accel/imu_info
              /camera/gyro/imu_info
              /diagnostics
              /aruco/target_pose
              /tag_detections
              $(arg mocap_topic)
              /mocap" />

</launch>
