<launch>
 
   <param name="use_sim_time" value="false" />
   
   <arg name="map" default="$(find myagv_navigation)/map/nav.yaml"/>
   <node pkg="map_server" type="map_server" name="map_server" args="$(arg map)"/> 
   <include file="$(find myagv_navigation)/launch/amcl.launch"/>
   <include file="$(find myagv_navigation)/launch/move_base.launch"/>
   <!--node pkg="tf" type="static_transform_publisher" name="map_odom_broadcaster" args="0 0 0 0 0 0 /map /odom 100" /-->
   <node pkg="rviz" type="rviz" name="rviz" args="-d $(find myagv_navigation)/rviz/gmapping.rviz"/>

</launch>



