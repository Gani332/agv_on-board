<launch>
  <arg name="node_namespace" default="apriltag_ros_continuous_node" />

  <rosparam command="load" file="$(find agv_bringup)/config/settings.yaml" ns="$(arg node_namespace)" />
  <rosparam command="load" file="$(find agv_bringup)/config/tags.yaml" ns="$(arg node_namespace)" />

  <node pkg="apriltag_ros" type="apriltag_ros_continuous_node" name="$(arg node_namespace)" clear_params="true" output="screen" >
    <remap from="image_rect" to="/camera/color/image_raw" />
    <remap from="camera_info" to="/camera/color/camera_info" />
    
    <param name="publish_tag_detections_image" type="bool" value="true" />
  </node>
</launch>
