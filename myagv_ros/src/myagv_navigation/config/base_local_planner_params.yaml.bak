#controller_frequency: 5 # 2
#recovery_behavior_enabled: flase
#clearing_rotation_allowed: flase

TrajectoryPlannerROS:
   max_vel_x: 1
   min_vel_x: -1 # 0.05
   max_vel_y: 1  # zero for a differential drive robot
   min_vel_y: -1 # 0.05
   max_vel_theta: 1  # zero for a differential drive robot
   min_vel_theta: 0.1
   max_rot_vel: 1.0
   min_rot_vel: 0.1
   min_in_place_vel_theta: 0.5 # 0.5
   escape_vel: -0.1
   acc_lim_x: 1
   acc_lim_y: 1 # zero for a differential drive robot
   acc_lim_theta: 5 #0.6

   holonomic_robot: true
   yaw_goal_tolerance: 0.5 # 0.1 # about 6 degrees
   xy_goal_tolerance: 0.25 # 0.2  # 10 cm
   #latch_xy_goal_tolerance: false
   path_distance_bias: 34 # 1.9
   goal_distance_bias: 24 # 0.3
   #meter_scoring: true

   #heading_lookahead: 0.325
   #heading_scoring: false
   #heading_scoring_timestep: 0.8
   occdist_scale: 0.1
   oscillation_reset_dist: 0.05
   publish_cost_grid_pc: false
   prune_plan: false

   sim_time: 3.0 #1.0
   sim_granularity: 0.1 # 0.025
   angular_sim_granularity: 0.1 #0.025
   vx_samples: 20
   vy_samples: 0 # zero for a differential drive robot
   vtheta_samples: 40
   use_dwa: true
   simple_attractor: false
