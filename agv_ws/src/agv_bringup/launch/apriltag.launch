<launch>
  <arg name="node_name" default="apriltag_ros_continuous_node" />
  <arg name="image_topic" default="/camera/color/image_raw" />
  <arg name="camera_info_topic" default="/camera/color/camera_info" />
  <arg name="settings_file" default="$(find agv_bringup)/config/settings.yaml" />
  <arg name="tags_file" default="$(find agv_bringup)/config/tags.yaml" />
  <arg name="publish_detection_image" default="false" />

  <node pkg="apriltag_ros"
        type="apriltag_ros_continuous_node"
        name="$(arg node_name)"
        clear_params="true"
        output="screen">
    <rosparam command="load" file="$(arg settings_file)" />
    <rosparam command="load" file="$(arg tags_file)" />

    <remap from="image_rect" to="$(arg image_topic)" />
    <remap from="camera_info" to="$(arg camera_info_topic)" />

    <param name="publish_tag_detections_image"
           type="bool"
           value="$(arg publish_detection_image)" />
  </node>
</launch>
